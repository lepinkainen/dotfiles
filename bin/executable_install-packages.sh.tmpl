{{ if eq .chezmoi.os "linux" -}}
{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}
{{/*
  Master CLI list — Debian/apt names. Linux mirror of the macOS Brewfile.
  Skipped (not in standard repos / installed separately): uv, llm, gemini-cli,
  claude-code, codex, watchman, doctl, terraform, go-task, gofumpt, golangci-lint,
  gopls, goimports, dust. Skipped (macOS-only): mas, pinentry-mac.
  Note: coreutils is part of every Linux base install — `timeout` is always present.
*/}}
{{- $packages := list
    "ack" "atuin" "awscli" "bat" "black" "btop" "curl"
    "direnv" "eza" "fastfetch" "fd-find" "ffmpeg" "fish" "fzf"
    "gallery-dl" "gh" "git" "git-delta" "git-lfs" "git-secrets" "gnupg"
    "golang-go" "helix" "httpie" "icdiff" "imagemagick" "jo" "jq"
    "less" "mosh" "neovim" "nodejs" "pinentry-tty" "pipenv"
    "postgresql" "python3" "ripgrep" "rsync" "ruff" "shellcheck"
    "starship" "tmux" "wget" "yt-dlp" "zoxide"
-}}
{{/* Arch uses different names for these. Empty value = drop (AUR only). */}}
{{- $arch_renames := dict
    "fd-find" "fd"
    "pinentry-tty" "pinentry"
    "golang-go" "go"
    "python3" "python"
    "awscli" "aws-cli"
    "black" "python-black"
    "gh" "github-cli"
    "pipenv" "python-pipenv"
    "git-secrets" ""
    "ack" ""
    "gallery-dl" ""
    "icdiff" ""
-}}
{{/* Packages only in Arch repos (pacman extra), not in Debian/Ubuntu main. */}}
{{- $arch_extras := list "duckdb" "lazygit" "yazi" -}}
#!/bin/sh
set -e

echo "Installing packages for Linux ({{ $osid }})..."

{{ if or (eq $osid "linux-debian") (eq $osid "linux-ubuntu") -}}
# Debian / Ubuntu
echo "Updating package lists..."
sudo apt update
PACKAGES="{{ join " " $packages }}"
echo "Installing packages: $PACKAGES"
sudo apt install -y $PACKAGES
echo ""
echo "Note: on Debian stable (bookworm), some packages live only in trixie/sid:"
echo "  atuin, eza, helix, ruff, yt-dlp, git-delta"
echo "Enable backports or upgrade if any of these fail."
echo "Not packaged for apt — install separately if needed:"
echo "  duckdb, lazygit, doctl, terraform, watchman, uv, llm, gemini-cli, claude-code"
{{ else if eq $osid "linux-arch" -}}
{{- $arch_pkgs := list -}}
{{- range $packages -}}
{{-   if hasKey $arch_renames . -}}
{{-     $renamed := get $arch_renames . -}}
{{-     if ne $renamed "" -}}
{{-       $arch_pkgs = append $arch_pkgs $renamed -}}
{{-     end -}}
{{-   else -}}
{{-     $arch_pkgs = append $arch_pkgs . -}}
{{-   end -}}
{{- end -}}
{{- range $arch_extras -}}{{- $arch_pkgs = append $arch_pkgs . -}}{{- end }}
# Arch Linux
PACKAGES="{{ join " " $arch_pkgs }}"
echo "Installing: $PACKAGES"
sudo pacman -Syu --noconfirm $PACKAGES
echo ""
echo "Not in official Arch repos — install via AUR or separately if needed:"
echo "  ack, gallery-dl, icdiff, git-secrets, doctl, terraform, watchman, uv, llm, gemini-cli, claude-code"
{{ else -}}
echo "Unsupported Linux distribution: {{ $osid }}"
echo "Please install the following packages manually:"
echo "  {{ join " " $packages }}"
exit 1
{{ end -}}

{{ else if eq .chezmoi.os "darwin" -}}
#!/bin/sh
set -e

echo "Installing packages for macOS..."

# Install Homebrew if not already installed
if [ ! -x "$(command -v brew)" ]; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
    echo "Homebrew already installed, updating..."
    brew update
fi

# Install packages from Brewfile
echo "Installing packages from Brewfile..."
brew bundle

# Install terminal and window management tools
echo "Installing terminal and window management tools..."
if [ -d "/Applications/Hammerspoon.app" ]; then
    echo "Hammerspoon already installed, skipping..."
elif brew list --cask hammerspoon &> /dev/null; then
    echo "Hammerspoon already installed via Homebrew, skipping..."
else
    echo "Installing Hammerspoon..."
    brew install --cask hammerspoon
fi

if [ -d "/Applications/Karabiner-Elements.app" ]; then
    echo "Karabiner-Elements already installed, skipping..."
elif brew list --cask karabiner-elements &> /dev/null; then
    echo "Karabiner-Elements already installed via Homebrew, skipping..."
else
    echo "Installing Karabiner-Elements..."
    brew install --cask karabiner-elements
fi

# Install fonts
echo "Installing fonts..."
for font in font-fira-mono-nerd-font font-fira-code-nerd-font font-fira-code font-fira-mono; do
    if ! brew list --cask "$font" &> /dev/null; then
        echo "Installing $font..."
        brew install "$font"
    else
        echo "$font already installed, skipping..."
    fi
done

{{ else if eq .chezmoi.os "windows" -}}
#!/bin/sh
echo "Windows not supported"
exit 1
{{ else -}}
#!/bin/sh
echo "Unsupported OS: {{ .chezmoi.os }}"
exit 1
{{ end -}}

echo "Package installation completed successfully!"