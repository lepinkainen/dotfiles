def _base_symbol(code: str) -> str:
    """Strip _day/_night/_polartwilight suffix."""
    for suffix in ("_day", "_night", "_polartwilight"):
        if code.endswith(suffix):
            return code[: -len(suffix)]
    return code


def symbol_to_emoji(code: str) -> str:
    if code in SYMBOL_EMOJI:
        return SYMBOL_EMOJI[code]
    base = _base_symbol(code)
    return SYMBOL_EMOJI.get(base, "?")


def symbol_to_name(code: str) -> str:
    base = _base_symbol(code)
    return SYMBOL_NAME.get(base, base.replace("_", " ").title())


# ---------------------------------------------------------------------------
# Color helpers
# ---------------------------------------------------------------------------


def temp_color(t: float) -> str:
    if t < 0:
        return "blue"
    if t < 10:
        return "cyan"
    if t < 20:
        return "white"
    if t < 30:
        return "yellow"
    return "red"


def wind_color(w: float) -> str:
    if w < 5:
        return "green"
    if w < 10:
        return "yellow"
    return "red"


def rain_color(mm: float) -> str:
    if mm <= 0:
        return "dim"
    if mm < 1:
        return "blue"
    return "bold blue"


# ---------------------------------------------------------------------------
# Display
# ---------------------------------------------------------------------------


def render(weather: WeatherData, location: Location, console: Console) -> None:
    c = weather.current

    # Location
    console.print(f"\n [dim]{location.name}[/dim]")

    # Current conditions header
    emoji = symbol_to_emoji(c.symbol_code)
    name = symbol_to_name(c.symbol_code)
    temp_styled = f"[{temp_color(c.temperature)}]{c.temperature:.0f}°C[/]"
    console.print(f" {emoji}  {name}  {temp_styled}\n")

    # UV warning (only if >= 3)
    if c.uv_index is not None and c.uv_index >= 3:
        uv_c = "red" if c.uv_index >= 6 else "yellow"
        console.print(
            f" [{uv_c}]UV {c.uv_index:.0f} — wear sunscreen![/]\n"
        )

    # 8-hour forecast table
    hours = weather.forecast
    if not hours:
        return

    table = Table(
        show_header=False,
        show_edge=False,
        show_lines=False,
        box=None,
        pad_edge=False,
        padding=(0, 1),
        expand=False,
    )

    # Label column + one column per hour
    table.add_column(style="dim", width=4, justify="right")
    for _ in hours:
        table.add_column(width=5, justify="right")

    # Row 1: hours
    table.add_row(
        "",
        *[Text(h.time.astimezone().strftime("%H"), style="bold") for h in hours],
    )

    # Row 2: weather emoji
    table.add_row("", *[symbol_to_emoji(h.symbol_code) for h in hours])

    # Row 3: temperature
    table.add_row(
        Text("°C", style="dim"),
        *[
            Text(f"{h.temperature:.0f}", style=temp_color(h.temperature))
            for h in hours
        ],
    )

    # Row 4: wind
    table.add_row(
        Text("m/s", style="dim"),
        *[
            Text(f"{h.wind_speed:.0f}", style=wind_color(h.wind_speed))
            for h in hours
        ],
    )

    # Row 5: rain
    table.add_row(
        Text("mm", style="dim"),
        *[
            Text(
                f"{h.precipitation_1h:.1f}" if h.precipitation_1h > 0 else "",
                style=rain_color(h.precipitation_1h),
            )
            for h in hours
        ],
    )

    console.print(table)
    console.print()


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    console = Console(stderr=True, width=80)

    if "--help" in sys.argv or "-h" in sys.argv:
        console.print("[bold]weather[/] — current conditions and 8-hour forecast\n")
        console.print("Usage:")
        console.print("  weather")
        console.print("  weather --location LAT,LON")
        console.print("  WEATHER_LOCATION=LAT,LON weather\n")
        console.print(
            "Location is resolved via macOS CoreLocation by default.\n"
            "Ensure your terminal has Location Services enabled in\n"
            "System Settings > Privacy & Security > Location Services."
        )
        sys.exit(0)

    try:
        location = get_location()
    except Exception as e:
        console.print(f"\n[red]Location error:[/] {e}")
        console.print("[yellow]Tip:[/] use --location LAT,LON to set manually\n")
        sys.exit(1)

    try:
        provider: WeatherProvider = MetNoProvider()
        weather = provider.fetch(location.lat, location.lon)
    except httpx.HTTPStatusError as e:
        console.print(f"\n[red]API error:[/] {e.response.status_code} {e.response.reason_phrase}")
        sys.exit(1)
    except httpx.RequestError as e:
        console.print(f"\n[red]Network error:[/] {e}")
        console.print("[yellow]Tip:[/] check your internet connection\n")
        sys.exit(1)

    render(weather, location, console)


if __name__ == "__main__":
    main()
