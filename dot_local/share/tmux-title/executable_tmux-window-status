#!/usr/bin/env bash
# tmux-window-status cmd title path
# Outputs: "<icon> <info>" for one window status entry.
# Arguments passed from .tmux.conf:
#   $1  pane_current_command
#   $2  pane_title
#   $3  pane_current_path

cmd="$1"
title="$2"
path="$3"

normalize_cmd() {
    case "$1" in batcat) printf 'bat' ;; vim|nvim) printf 'vi' ;; *) printf '%s' "$1" ;; esac
}

command_icon() {
    case "$1" in
        fish)                   printf '🐟' ;;
        bash)                   printf '💩' ;;
        python3|python)         printf '🐍' ;;
        git)                    printf '🔀' ;;
        find|ag|rg|fd)          printf '🔍' ;;
        sleep)                  printf '🕓' ;;
        docker)                 printf '📦' ;;
        sudo)                   printf '💥' ;;
        cp|rsync|dd)            printf '💾' ;;
        ssh|scp)                printf '📡' ;;
        curl|wget|gh)           printf '🌐' ;;
        eza|mc)                 printf '🗂️' ;;
        vi|hx|nano)             printf '✏️' ;;
        bat|less|cat)           printf '📃' ;;
        man)                    printf '📖' ;;
        task)                   printf '✅' ;;
        uv)                     printf '⚡' ;;
        chezmoi)                printf '🏠' ;;
        claude|pi|codex)        printf '🤖' ;;
        brew)                   printf '🍺' ;;
        code)                   printf '💻' ;;
        tofu)                   printf '🧱' ;;
        llm)                    printf '🧠' ;;
        poetry)                 printf '📜' ;;
        gemini)                 printf '✨' ;;
        yt-dlp)                 printf '📥' ;;
        open)                   printf '🚪' ;;
        du)                     printf '📏' ;;
        mkdir)                  printf '📁' ;;
        mv)                     printf '📦' ;;
        rm)                     printf '🗑️' ;;
        go)                     printf '🐹' ;;
        *)                      printf '%s' "$1" ;;
    esac
}

command_title_mode() {
    case "$1" in
        ssh|scp)                printf 'remote' ;;
        vi|bat|less|man)        printf 'short' ;;
    esac
}

command_display_name() {
    case "$1" in
        pi)                     printf 'π' ;;
        claude)                 printf 'Claude Code' ;;
        codex)                  printf 'Codex' ;;
        gemini)                 printf 'Gemini' ;;
        *)                      printf '%s' "$1" ;;
    esac
}

is_version_like_title() {
    local raw_title="$1"
    [[ "$raw_title" =~ ^v?[0-9]+(\.[0-9]+)+([[:space:]].*)?$ ]]
}

# Note: value is shortened by default fish_title to 10 characters
host_label() {
    case "$1" in
        hime)                   printf '🎬' ;;
        raspberryp)             printf '🤖' ;;
        prox)                   printf '🛠️' ;;
        orochi)                 printf '🚗' ;;
        *)                      printf '%s' "${1:0:4}" ;;
    esac
}

short_title() {
    local raw_title="$1"
    local normalized_cmd="$2"
    local original_title_cmd="$3"
    local short_info="$raw_title"

    short_info="${short_info#"$normalized_cmd" }"
    short_info="${short_info#"$original_title_cmd" }"
    short_info="${short_info% - "${original_title_cmd^^}"}"  # strip trailing " - CMD" suffix (e.g. nvim → " - NVIM", vim → " - VIM")
    short_info="${short_info% [~\/]*}"       # strip trailing path-like word
    printf '%s' "$short_info"
}

infer_special_app() {
    local raw_title="$1"
    local lower_title="${raw_title,,}"

    case "$lower_title" in
        *"claude code"*|*"claude"*) printf 'claude' ;;
        *"codex"*)                    printf 'codex' ;;
        *"gemini"*)                   printf 'gemini' ;;
        "pi"|"pi "*|*" pi"|"π"|"π "*|*" π") printf 'pi' ;;
    esac
}

clean_special_title() {
    local cleaned="$1"

    # Strip common leading version prefixes and spinner/punctuation markers.
    cleaned="$(printf '%s' "$cleaned" | perl -pe 's/^v?\d+(?:\.\d+)+(?:[-+][A-Za-z0-9._-]+)?\s+//; s/^[[:punct:]✳★☆•·⋅✦✱✲✴✷✸✹✺✻✼✽✾✿❋❊❉❈❇]+\s*//;')"
    printf '%s' "$cleaned"
}

# normalize aliases so icon + title-strip logic can use one canonical name
# original_cmd is kept for suffix stripping (e.g. "- VIM", "- NVIM")
original_cmd="$cmd"
cmd="$(normalize_cmd "$cmd")"

# Some tools expose a useless command name (wrapper binary, version string) but a useful pane title.
# Prefer the title when it clearly identifies a known app.
wrapped_app="$(infer_special_app "$title")"
if [[ -n "$wrapped_app" ]] && { [[ "$cmd" =~ ^(node|bun|deno|python|python3)$ ]] || is_version_like_title "$cmd"; }; then
    original_cmd="$wrapped_app"
    cmd="$wrapped_app"
    title="$(clean_special_title "$title")"
fi

# --- icon + title mode ---
icon="$(command_icon "$cmd")"
title_mode="$(command_title_mode "$cmd")"

if [[ "$title" =~ ^\[([^]]+)\][[:space:]]*(.*)$ ]]; then
    remote="$(host_label "${BASH_REMATCH[1]}")"
    remote_title="${BASH_REMATCH[2]}"

    remote_original_cmd="${remote_title%% *}"
    remote_cmd="$(normalize_cmd "$remote_original_cmd")"
    remote_icon="$(command_icon "$remote_cmd")"
    remote_title_mode="$(command_title_mode "$remote_cmd")"

    if [[ "$cmd" == ssh || "$cmd" == scp ]] && [[ "$remote_icon" == "$remote_cmd" && -z "$remote_title_mode" ]]; then
        if [[ -n "$remote_title" ]]; then
            printf '📡 %s %s' "$remote" "$remote_title"
        else
            printf '📡 %s' "$remote"
        fi
        exit 0
    fi

    if [[ "$remote_title_mode" == short ]]; then
        remote_info="$(short_title "$remote_title" "$remote_cmd" "$remote_original_cmd")"
    else
        remote_info="${remote_title#"$remote_original_cmd"}"
        remote_info="${remote_info#"${remote_info%%[![:space:]]*}"}"
    fi

    if [[ -n "$remote_info" ]]; then
        printf '📡 %s %s %s' "$remote" "$remote_icon" "$remote_info"
    else
        printf '📡 %s %s' "$remote" "$remote_icon"
    fi
    exit 0
fi

# --- info ---
if [[ "$title_mode" == remote ]]; then
    remote_title="${title#"$cmd" }"        # strip leading "cmd " if present
    remote_title="${remote_title% - "${original_cmd^^}"}"
    if [[ "$remote_title" =~ ^\[([^]]+)\][[:space:]]*(.*)$ ]]; then
        remote="$(host_label "${BASH_REMATCH[1]}")"
        remote_path="${BASH_REMATCH[2]}"
    else
        remote="${remote_title%% *}"
        remote_path="${remote_title#"$remote"}"
        remote_path="${remote_path#"${remote_path%%[![:space:]]*}"}"
        remote="${remote#\[}"
        remote="${remote%\]}"
        remote="$(host_label "$remote")"
    fi
    if [[ -n "$remote_path" ]]; then
        info="$remote $remote_path"
    else
        info="$remote"
    fi
elif [[ "$cmd" =~ ^(pi|claude|codex|gemini)$ ]]; then
    if [[ -z "$title" ]] || is_version_like_title "$title"; then
        info="$(command_display_name "$cmd")"
    else
        info="$title"
    fi
elif [[ "$title_mode" == short ]]; then
    info="$(short_title "$title" "$cmd" "$original_cmd")"
else
    display="${path/$HOME/\~}"
    if [[ "$display" != */* ]]; then
        # path is $HOME itself or a single-component path like /tmp
        info="$display"
    else
        base="${display##*/}"
        parent_path="${display%/*}"
        parent="${parent_path##*/}"
        if [[ -z "$parent" ]]; then
            candidate="/$base"         # e.g. /tmp
        else
            candidate="$parent/$base"  # e.g. ~/bin or projects/myapp
        fi
        if [[ ${#candidate} -lt 20 ]]; then
            info="$candidate"
        else
            info="$base"
        fi
    fi
fi

printf '%s %s' "$icon" "$info"
