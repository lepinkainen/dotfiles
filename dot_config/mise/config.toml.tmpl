[bootstrap.macos.defaults]
# Dock/Finder/keyboard tweaks — opinionated, enable what you want, then
# `mise bootstrap macos-defaults apply`. Examples (commented until you choose):
"com.apple.finder" = { AppleShowAllExtensions = true, ShowPathbar = true, _FXSortFoldersFirst = true }
# "com.apple.dock"   = { autohide = true, tilesize = 48 }
# "NSGlobalDomain"   = { KeyRepeat = 2, InitialKeyRepeat = 15, AppleShowAllExtensions = true }

{{ else if eq .chezmoi.os "linux" -}}
# ---------------------------------------------------------------------------
# Linux — personal Debian VMs/VPSs.
# Unlike macOS there is no brew dependency tangle, so runtimes AND modern CLI
# tools live in mise [tools] (latest prebuilt binaries, cross-distro). apt only
# provides the base system + shell + things mise shouldn't own.
# ---------------------------------------------------------------------------

[tools]
# Runtimes (clean on Linux — no dependent system packages blocking them).
node = "lts"
go = "latest"
# Modern CLI tools apt lacks or ships stale — mise pulls prebuilt binaries.
eza = "latest"
zoxide = "latest"
starship = "latest"
atuin = "latest"
lazygit = "latest"
delta = "latest"      # git-delta
fd = "latest"
ripgrep = "latest"
bat = "latest"
fzf = "latest"
gh = "latest"
neovim = "latest"
fastfetch = "latest"
dust = "latest"

[bootstrap.packages]
{{ if eq (.chezmoi.osRelease.id | default "") "debian" -}}
# Base system + shell + tools better owned by apt (system integration, build deps).
"apt:fish" = "latest"
"apt:tmux" = "latest"
"apt:git" = "latest"
"apt:curl" = "latest"
"apt:wget" = "latest"
"apt:rsync" = "latest"
"apt:mosh" = "latest"
"apt:gnupg" = "latest"
"apt:pinentry-tty" = "latest"
"apt:python3" = "latest"
"apt:less" = "latest"
"apt:htop" = "latest"
"apt:btop" = "latest"
"apt:jq" = "latest"
"apt:ca-certificates" = "latest"
"apt:build-essential" = "latest"
{{ else if eq (.chezmoi.osRelease.id | default "") "arch" -}}
# Same base system, Arch package names (pinentry, python, base-devel).
"pacman:fish" = "latest"
"pacman:tmux" = "latest"
"pacman:git" = "latest"
"pacman:curl" = "latest"
"pacman:wget" = "latest"
"pacman:rsync" = "latest"
"pacman:mosh" = "latest"
"pacman:gnupg" = "latest"
"pacman:pinentry" = "latest"
"pacman:python" = "latest"
"pacman:less" = "latest"
"pacman:htop" = "latest"
"pacman:btop" = "latest"
"pacman:jq" = "latest"
"pacman:ca-certificates" = "latest"
"pacman:base-devel" = "latest"
{{ else -}}
# Unknown Linux distro: {{ .chezmoi.osRelease.id | default "?" }} — add a branch.
{{ end -}}

{{ else -}}
[tools]
{{ end -}}
