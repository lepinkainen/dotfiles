# Global mise config. Rendered by chezmoi per-OS.
#
# Ownership (see ansible repo migration plan):
#   mise            -> system packages (formulae) + versioned dev runtimes + bootstrap tasks
#   chezmoi         -> dotfiles, secrets (age), and CASKS via Brewfile/run_onchange
#                      (mise's brew backend does NOT support casks)
#   direnv          -> per-project env (kept minimal)
#
# Manual flow for now:  mise bootstrap   (not wired into run_onchange yet)

[settings]
# `mise bootstrap` is experimental in 2026.6.x and refuses to run without this.
experimental = true

{{ if eq .chezmoi.os "darwin" -}}
# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------

[tools]
# (empty for now — no runtimes are mise-managed yet.)
# NOTE: `go` and `node` intentionally stay in brew (below). Brew formulae depend
# on them — go: gofumpt/golangci-lint/gopls/goimports/go-task; node:
# gemini-cli/opencode/typescript/typescript-language-server/vscode-langservers-extracted
# — so `brew uninstall` is refused while those exist. See README.md "Path B" to
# move a runtime fully to mise.
# NOTE: python/uv/pipenv also left in Brewfile for now to avoid disrupting the
# existing python toolchain. Move here later if desired.

[bootstrap.packages]
# Homebrew FORMULAE only (casks remain in Brewfile). Ported from Brewfile.
