# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values

font-family = Fira Code
font-size = 13

background = #100F0F
foreground = #CECDC3

# resize-overlay-duration = 4s 200ms

theme = Flexoki Dark

# Font options - enable ligatures for Fira Code

font-feature = +calt,+liga

# Better font rendering on macOS

font-thicken = true

# Window decoration

window-decoration = true
macos-titlebar-style = tabs

# Window padding for breathing room

window-padding-x = 4
window-padding-y = 4

# Shell integration enables features like jump-to-prompt, command completion markers

shell-integration = detect

# Clipboard settings

clipboard-read = allow
clipboard-write = allow
copy-on-select = true
clipboard-trim-trailing-spaces = true

# Productivity settings

scrollback-limit = 100000
mouse-hide-while-typing = true
confirm-close-surface = true
auto-update = check
window-step-resize = true

# Visual effects

unfocused-split-opacity = 0.8
background-blur-radius = 20
background-opacity = 0.95
resize-overlay = always
resize-overlay-duration = 1s

# copy terminfo on ssh conneection, set TERM if failed

shell-integration-features = ssh-env

# 50MB

scrollback-limit = 52428800

# shift-enter = newline in claude

keybind = shift+enter=text:\x1b\r

# Always start new tabs/windows in HOME

window-inherit-working-directory = false
working-directory = home
