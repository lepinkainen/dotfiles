# This is the configuration file for Ghostty.

# Theme stuff
theme = Flexoki Dark

font-family = Fira Code
font-size = 13
font-feature = +calt,+liga
# Makes the font less thin and more readable
font-thicken = true

# Cooler icon
macos-icon = retro

# tabs in the titlebar
macos-titlebar-style = tabs

# Visual effects
unfocused-split-opacity = 0.8
background-opacity = 0.95
background-blur = true

# Shell integration enables features like jump-to-prompt, command completion markers
shell-integration = detect
# copy terminfo on ssh conneection, set TERM if failed
shell-integration-features = ssh-env,title

# Clipboard stuff
clipboard-read = allow
clipboard-write = allow
copy-on-select = true
clipboard-trim-trailing-spaces = true

# Scrolling
scrollback-limit = 52428800
mouse-hide-while-typing = true
confirm-close-surface = true

auto-update = check
# both option keys are option keys
macos-option-as-alt = false

# New tabs and windows start in home
window-step-resize = true
window-inherit-working-directory = false
working-directory = home
